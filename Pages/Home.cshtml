@page
@model DemoLayouts.Pages.HomeModel
@{
    ViewData["Title"] = "Tổng hợp Bài tập Chương 4";
}

<div class="container mt-4">
    <div class="text-center mb-5">
        <h1 class="display-4 text-primary">Welcome</h1>
        <p class="lead">Hệ thống quản lý sản phẩm</p>
    </div>

    <div class="row">
        <div class="col-md-6">
            <h4 class="text-info">Bài 3: Sắp xếp Tăng dần</h4>
            @await Component.InvokeAsync("ProductList", new { sapXepTang = true })
        </div>

        <div class="col-md-6">
            <h4 class="text-danger">Bài 3: Sắp xếp Giảm dần</h4>
            @await Component.InvokeAsync("ProductList", new { sapXepTang = false })
        </div>
    </div>

    <hr />

    <div class="row justify-content-center mt-4">
        <div class="col-md-8">
            <h4 class="text-warning">Bài 2: Sản phẩm bán chạy (Top 3)</h4>
            @await Component.InvokeAsync("BestSellers", new { count = 3 })
        </div>
    </div>
</div>